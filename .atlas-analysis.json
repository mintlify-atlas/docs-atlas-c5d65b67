  "projectType": "api-service",
  "projectName": "Ecommerce Delivery API",
  "projectDescription": "A Node.js/Express REST API backend for an e-commerce delivery platform, handling users, products, sales orders, and real-time push notifications via Firebase Cloud Messaging.",
  "theme": "luma",
